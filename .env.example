# === 必填项 ===

# Session Cookie (从浏览器获取，用于自动刷新 JWT)
# 获取方法：F12 → Application → Cookies → api.lexika.ai → __Secure-better-auth.session_token
LEXIKA_COOKIES=__Secure-better-auth.session_token=你的session_token值

# 工作区 ID (从浏览器 HAR 或 Cookie 中获取)
LEXIKA_WORKSPACE_ID=你的工作区ID

# === 可选项 (有默认值) ===

# JWT Token (留空则启动时自动用 Cookie 刷新获取)
LEXIKA_JWT_TOKEN=

# 默认模型
MODEL_NAME=claude-sonnet-4-6

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 代理 API 密钥 (客户端调用时使用)
API_KEY=sk-lexika-proxy

# DSML 工具调用 (true/false)
DSML_ENABLED=false

# Lexika API 地址
LEXIKA_BASE_URL=https://api.lexika.ai
LEXIKA_ORIGIN=https://lexika.ai
LEXIKA_LOCALE=en

# HTTP 代理 (可选，如 http://127.0.0.1:7890)
LEXIKA_PROXY=